# ── DATABASE ──────────────────────────────────────────────────────────────────
# Neon Postgres pooled connection (used at runtime by Vercel serverless)
DATABASE_URL="postgres://user:password@neon-pooled-host/db?sslmode=require&pgbouncer=true"

# Neon Postgres direct connection (used only for prisma migrate / prisma db push)
DIRECT_URL="postgres://user:password@neon-direct-host/db?sslmode=require"

# ── SUPABASE ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# ── AI / VOICE ────────────────────────────────────────────────────────────────
# Groq API (used for AI assistant + Whisper transcription fallback)
GROQ_API_KEY="gsk_your_groq_api_key"

# Sarvam AI (primary voice transcription for Indian languages)
SARVAM_API_KEY="your_sarvam_api_key"

# ── GOOGLE SHEETS SYNC ────────────────────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_EMAIL="your-service-account@your-project-id.iam.gserviceaccount.com"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID="your-google-sheet-id"

# ── WEB PUSH NOTIFICATIONS ────────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"

# ── CRON JOB SECURITY ─────────────────────────────────────────────────────────
# Set in Vercel env vars too — protects /api/cron/due-tomorrow from public access
# Generate with: openssl rand -base64 32
CRON_SECRET="your-random-secret-string"

# ── APP CONFIG ────────────────────────────────────────────────────────────────
# Your production Vercel URL (used for QR codes and WhatsApp links)
NEXT_PUBLIC_APP_URL="https://mr-boot-crm.vercel.app"

WHATSAPP_BUSINESS_NUMBER="919028983659"
