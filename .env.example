# Neon Postgres pooled connection string for serverless (Vercel)
DATABASE_URL="postgres://user:password@neon-pooled-host/db?sslmode=require&pgbouncer=true"

# Neon Postgres direct connection string for running migrations
DIRECT_URL="postgres://user:password@neon-direct-host/db?sslmode=require"

# Supabase Auth and Storage URL and Anon Key
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Supabase Service Role Key for bypassing RLS/admin tasks on the server
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Groq API Key (llama-3.3-70b-versatile or similar)
GROQ_API_KEY="gsk_your_groq_api_key"

# Google Service Account for Sheet Sync
GOOGLE_SERVICE_ACCOUNT_EMAIL="your-service-account@your-project-id.iam.gserviceaccount.com"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID="your-google-sheet-id"

# App public URL (used for QR code links and WhatsApp triggers)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# WhatsApp Business Number or Contact Number for wa.me redirect
WHATSAPP_BUSINESS_NUMBER="1234567890"
